<mujoco model="dexgrasp_shadowhand_arm_scene">
  <compiler angle="radian" coordinate="local" inertiafromgeom="true"
    meshdir="../../third_party/mujoco_menagerie/shadow_hand/assets"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <!-- ShadowHand model with freejoint root to allow arm attachment. -->
  <include file="right_hand_local.xml"/>

  <visual>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="8192"/>
    <global azimuth="220" elevation="-30"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <default>
    <geom type="capsule" rgba="0.6 0.6 0.6 1" condim="6" friction="0.8 0.1 0.01"/>
    <joint type="hinge" damping="2" armature="0.01" limited="true"/>
  </default>

  <worldbody>
    <light pos="0.4 0 1.2" dir="0 0 -1" directional="true" diffuse="0.9 0.9 0.9" specular="0.2 0.2 0.2"/>
    <light pos="0.6 0.3 0.8" dir="-0.2 -0.2 -1" directional="true" diffuse="0.6 0.6 0.6" specular="0.1 0.1 0.1"/>
    <geom name="floor" pos="0 0 -0.1" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="table" pos="0.6 0 0">
      <geom name="table_geom" type="box" size="0.3 0.3 0.025" pos="0 0 0.025" rgba="0.4 0.3 0.2 1" condim="6"/>
    </body>

    <!-- Arm points toward +X (toward the table) -->
    <body name="arm_base" pos="0.0 -0.4 0.25" quat="0.7071068 0 0.7071068 0">
      <geom name="arm_link_1" fromto="0 0 0 0 0 0.3" size="0.04"/>
      <joint name="arm_joint_1" axis="0 0 1" range="-3.1 3.1"/>

      <body name="arm_link_2" pos="0 0 0.3">
        <geom name="arm_link_2_geom" fromto="0 0 0 0 0 0.3" size="0.035"/>
        <joint name="arm_joint_2" axis="0 1 0" range="-2.268 2.268"/>

        <body name="arm_link_3" pos="0 0 0.3">
          <geom name="arm_link_3_geom" fromto="0 0 0 0 0 0.3" size="0.035"/>
          <joint name="arm_joint_3" axis="0 0 1" range="-3.1 3.1"/>

          <body name="arm_link_4" pos="0 0 0.3">
            <geom name="arm_link_4_geom" fromto="0 0 0 0 0 0.25" size="0.03"/>
            <joint name="arm_joint_4" axis="0 1 0" range="-2.355 2.355"/>

            <body name="arm_link_5" pos="0 0 0.25">
              <geom name="arm_link_5_geom" fromto="0 0 0 0 0 0.25" size="0.03"/>
              <joint name="arm_joint_5" axis="0 0 1" range="-3.1 3.1"/>

              <body name="arm_link_6" pos="0 0 0.25">
                <geom name="arm_link_6_geom" fromto="0 0 0 0 0 0.2" size="0.025"/>
                <joint name="arm_joint_6" axis="0 1 0" range="-2.233 2.233"/>

                <body name="arm_link_7" pos="0 0 0.2">
                  <geom name="arm_link_7_geom" fromto="0 0 0 0 0 0.15" size="0.025"/>
                  <joint name="arm_joint_7" axis="0 0 1" range="-6.28 6.28"/>

                  <body name="arm_ee" pos="0 0 0.15">
                    <geom name="arm_ee_geom" type="sphere" size="0.04" rgba="0.4 0.4 0.7 1"/>
                    <site name="arm_wrist_site" pos="0 0 0" size="0.005"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Fixed world view: top-down above the table -->
    <camera name="third" pos="0.6 0 1.0" xyaxes="1 0 0 0 1 0" fovy="60"/>

    <!-- Wrist camera mounted to the hand (along fingers, thumb-side offset). -->
    <body name="hand_cam_mount">
      <camera name="wrist" pos="0 0 0" xyaxes="1 0 0 0 -1 0" fovy="40"/>
    </body>

    <body name="object" pos="0.6 0 0.12">
      <freejoint/>
      <geom name="object_geom" type="box" size="0.03 0.03 0.03" rgba="0.5 0.7 0.5 1" condim="6"
        friction="0.5 0.01 0.003"/>
    </body>
  </worldbody>

  <equality>
    <!-- Menagerie right_hand.xml root body is rh_forearm. -->
    <weld name="weld_hand_to_arm" body1="arm_ee" body2="rh_forearm" relpose="0 0 0.06 1 0 0 0"/>
    <!-- Mount wrist camera on the hand (thumb-side), looking along fingers. -->
    <weld name="weld_wrist_cam" body1="rh_wrist" body2="hand_cam_mount" relpose="0 0.03 0.06 1 0 0 0"/>
  </equality>

  <actuator>
    <position name="arm_act_1" joint="arm_joint_1" kp="200" ctrlrange="-3.1 3.1"/>
    <position name="arm_act_2" joint="arm_joint_2" kp="200" ctrlrange="-2.268 2.268"/>
    <position name="arm_act_3" joint="arm_joint_3" kp="200" ctrlrange="-3.1 3.1"/>
    <position name="arm_act_4" joint="arm_joint_4" kp="200" ctrlrange="-2.355 2.355"/>
    <position name="arm_act_5" joint="arm_joint_5" kp="200" ctrlrange="-3.1 3.1"/>
    <position name="arm_act_6" joint="arm_joint_6" kp="200" ctrlrange="-2.233 2.233"/>
    <position name="arm_act_7" joint="arm_joint_7" kp="200" ctrlrange="-6.28 6.28"/>
  </actuator>
</mujoco>

